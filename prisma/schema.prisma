generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  username           String              @unique
  password           String
  role               String
  contact            String?
  createdAt          DateTime            @default(now())
  email              String?             @unique
  passwordHash       String?
  saasRole           Role?
  tenantId           String?
  branchId           String?
  isActive           Boolean             @default(true)
  lastActiveAt       DateTime?
  dynamicRoleId      String?
  businessUsername   String?
  mustChangePassword Boolean             @default(false)
  failedLoginCount   Int                 @default(0)
  lockedUntil        DateTime?
  lastPasswordChange DateTime?
  branch             Branch?             @relation(fields: [branchId], references: [id])
  dynamicRole        DynamicRole?        @relation(fields: [dynamicRoleId], references: [id])
  tenant             Tenant?             @relation(fields: [tenantId], references: [id])
  createdProducts    Product[]           @relation("ProductCreator")
  stockAdjustments   StockAdjustment[]   @relation("StockAdjuster")
  inventoryAuditLogs InventoryAuditLog[] @relation("AuditPerformer")
  revertedAuditLogs  InventoryAuditLog[] @relation("AuditReverter")

  @@index([tenantId])
}

model Product {
  id                Int       @id @default(autoincrement())
  name              String
  brand             String?
  category          String
  unit              String    @default("Piece")
  sku               String?
  price             Float // selling_price (derived from cost × markup)
  costPrice         Float? // wholesale cost price
  markupPercent     Float     @default(0) // markup percentage
  stockQty          Int       @default(0)
  lowStockThreshold Int       @default(10)
  expiryDate        DateTime? // nearest_expiry_date across batches
  description       String?
  isActive          Boolean   @default(true) // soft-delete
  supplierId        Int?
  createdBy         Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tenantId          String?

  tenant             Tenant?             @relation(fields: [tenantId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  creator            User?               @relation("ProductCreator", fields: [createdBy], references: [id])
  saleItems          SaleItem[]
  stockAdjustments   StockAdjustment[]
  inventoryAuditLogs InventoryAuditLog[] @relation("AuditProduct")

  @@unique([tenantId, sku])
  @@index([name])
  @@index([isActive])
  @@index([supplierId])
  // Hot path: inventory list query filters by tenantId + isActive
  @@index([tenantId, isActive])
}

model Supplier {
  id          Int      @id @default(autoincrement())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  isActive    Boolean  @default(true)
  tenantId    String?
  createdAt   DateTime @default(now())

  tenant             Tenant?             @relation(fields: [tenantId], references: [id])
  products           Product[]
  inventoryAuditLogs InventoryAuditLog[] @relation("AuditSupplier")

  @@index([name])
  @@index([tenantId, isActive])
}

model StockAdjustment {
  id          Int      @id @default(autoincrement())
  productId   Int
  adjustedBy  Int
  oldQuantity Int
  newQuantity Int
  delta       Int // new - old
  reason      String // enum value
  notes       String?
  tenantId    String?
  adjustedAt  DateTime @default(now())

  product  Product @relation(fields: [productId], references: [id])
  adjuster User    @relation("StockAdjuster", fields: [adjustedBy], references: [id])
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  @@index([productId])
  @@index([tenantId, adjustedAt(sort: Desc)])
}

model InventoryAuditLog {
  id          Int       @id @default(autoincrement())
  actionType  String // e.g. PRODUCT_CREATED, PRICE_UPDATED, etc.
  productId   Int?
  supplierId  Int?
  performedBy Int
  oldValue    Json? // snapshot before change
  newValue    Json? // snapshot after change
  notes       String?
  tenantId    String?
  performedAt DateTime  @default(now())
  revertedAt  DateTime? // null = not reverted
  revertedBy  Int? // userId who reverted
  revertNote  String? // optional reason for revert

  product   Product?  @relation("AuditProduct", fields: [productId], references: [id])
  supplier  Supplier? @relation("AuditSupplier", fields: [supplierId], references: [id])
  performer User      @relation("AuditPerformer", fields: [performedBy], references: [id])
  reverter  User?     @relation("AuditReverter", fields: [revertedBy], references: [id])
  tenant    Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([productId])
  @@index([performedAt(sort: Desc)])
  @@index([tenantId, performedAt(sort: Desc)])
  @@index([actionType])
}

model Category {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  markupPercent Float   @default(30) // default markup % for this category
  tenantId      String?

  @@index([tenantId])
}

model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String?
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())
  tenantId      String?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])
  sales         Sale[]

  @@unique([tenantId, phone])
}

model Sale {
  id          Int        @id @default(autoincrement())
  totalAmount Float
  discount    Float      @default(0)
  paymentType String
  status      String
  customerId  Int?
  sellerId    Int
  createdAt   DateTime   @default(now())
  tenantId    String?
  clientToken String?    @unique
  miscItems   String?
  customer    Customer?  @relation(fields: [customerId], references: [id])
  tenant      Tenant?    @relation(fields: [tenantId], references: [id])
  items       SaleItem[]

  // Dashboards & reports query sales by tenant within a date range
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([customerId])
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  productId Int
  quantity  Int
  price     Float
  product   Product @relation(fields: [productId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id])

  @@index([saleId])
  @@index([productId])
}

model Tenant {
  id                     String                  @id @default(cuid())
  name                   String
  subdomain              String                  @unique
  primaryColor           String                  @default("#6366f1")
  secondaryColor         String                  @default("#8b5cf6")
  logoUrl                String?
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  businessId             String?                 @unique
  legalName              String?
  address                String?
  licenceNumber          String?
  taxVatNumber           String?
  subscriptionTier       String                  @default("basic")
  primaryContact         String?
  primaryPhone           String?
  primaryEmail           String?
  baseColor              String?                 @default("#6366f1")
  contrast               Float?                  @default(0.7)
  customSidebar          Boolean                 @default(false)
  sidebarColor           String?
  auditLogs              AuditLog[]
  branches               Branch[]
  customers              Customer[]
  dynamicMenuConfigs     DynamicMenuConfig[]
  dynamicRoles           DynamicRole[]
  dynamicRolePermissions DynamicRolePermission[]
  loginAttempts          LoginAttempt[]
  menuConfigs            MenuConfig[]
  products               Product[]
  suppliers              Supplier[]
  stockAdjustments       StockAdjustment[]
  inventoryAuditLogs     InventoryAuditLog[]
  rolePermissions        RolePermission[]
  sales                  Sale[]
  featureFlags           TenantFeatureFlag[]
  users                  User[]
}

model Branch {
  id       String  @id @default(cuid())
  name     String
  tenantId String
  address  String?
  phone    String?
  isActive Boolean @default(true)
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  users    User[]
}

model Permission {
  id       String @id @default(cuid())
  key      String @unique
  label    String
  category String
}

model RolePermission {
  id            String @id @default(cuid())
  tenantId      String
  role          Role
  permissionKey String
  tenant        Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, role, permissionKey])
}

model MenuConfig {
  id        String @id @default(cuid())
  tenantId  String
  role      Role
  menuItems String
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, role])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String?
  action    String
  metadata  String?
  createdAt DateTime @default(now())
  ipAddress String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
}

model DynamicRole {
  id          String                  @id @default(cuid())
  tenantId    String?
  name        String
  slug        String
  description String?
  level       Int                     @default(3)
  isSystem    Boolean                 @default(false)
  isActive    Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  menuConfigs DynamicMenuConfig[]
  tenant      Tenant?                 @relation(fields: [tenantId], references: [id])
  permissions DynamicRolePermission[]
  users       User[]

  @@unique([tenantId, slug])
}

model DynamicRolePermission {
  id            String      @id @default(cuid())
  dynamicRoleId String
  permissionKey String
  tenantId      String
  dynamicRole   DynamicRole @relation(fields: [dynamicRoleId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([dynamicRoleId, permissionKey])
}

model DynamicMenuConfig {
  id            String      @id @default(cuid())
  dynamicRoleId String
  tenantId      String
  menuItems     String
  dynamicRole   DynamicRole @relation(fields: [dynamicRoleId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([dynamicRoleId, tenantId])
}

model FeatureFlag {
  id           String              @id @default(cuid())
  key          String              @unique
  label        String
  description  String?
  category     String
  isGloballyOn Boolean             @default(false)
  createdAt    DateTime            @default(now())
  tenantFlags  TenantFeatureFlag[]
}

model TenantFeatureFlag {
  id            String      @id @default(cuid())
  tenantId      String
  featureFlagId String
  isEnabled     Boolean     @default(false)
  featureFlag   FeatureFlag @relation(fields: [featureFlagId], references: [id])
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, featureFlagId])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String?
  username  String?
  tenantId  String?
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  // Hot path: IP rate-limit counts failures by ipAddress within a time window
  @@index([ipAddress, createdAt])
}

enum Role {
  SUPER_ADMIN
  MANAGER
  MCA
  NES
}
