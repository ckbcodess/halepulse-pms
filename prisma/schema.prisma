generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  username           String              @unique
  password           String
  role               String
  contact            String?
  createdAt          DateTime            @default(now())
  email              String?             @unique
  passwordHash       String?
  saasRole           Role?
  tenantId           String?
  branchId           String?
  isActive           Boolean             @default(true)
  lastActiveAt       DateTime?
  dynamicRoleId      String?
  businessUsername   String?
  mustChangePassword Boolean             @default(false)
  failedLoginCount   Int                 @default(0)
  lockedUntil        DateTime?
  lastPasswordChange DateTime?
  branch             Branch?             @relation(fields: [branchId], references: [id])
  dynamicRole        DynamicRole?        @relation(fields: [dynamicRoleId], references: [id])
  tenant             Tenant?             @relation(fields: [tenantId], references: [id])
  createdProducts    Product[]           @relation("ProductCreator")
  stockAdjustments   StockAdjustment[]   @relation("StockAdjuster")
  inventoryAuditLogs InventoryAuditLog[] @relation("AuditPerformer")
  revertedAuditLogs  InventoryAuditLog[] @relation("AuditReverter")
  grnReceived        GoodsReceivedNote[] @relation("GrnReceiver")
  stockMovements     StockMovement[]     @relation("MovementPerformer")
  stockTakesInitiated StockTakeSession[] @relation("StockTakeInitiator")
  stockTakesCompleted StockTakeSession[] @relation("StockTakeCompleter")

  @@index([tenantId])
}

model Product {
  id                Int       @id @default(autoincrement())
  name              String
  brand             String?
  category          String
  unit              String    @default("Piece")
  sku               String?
  price             Float // selling_price (derived from cost × markup)
  costPrice         Float? // wholesale cost price
  markupPercent     Float     @default(0) // markup percentage
  stockQty          Int       @default(0)
  lowStockThreshold Int       @default(10)
  expiryDate        DateTime? // nearest_expiry_date across batches
  description       String?
  isActive          Boolean   @default(true) // soft-delete
  requiresPrescription Boolean @default(false) // POS prompts for an Rx reference
  isControlled         Boolean @default(false) // extra logging on dispensing
  supplierId        Int?
  createdBy         Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tenantId          String?

  tenant             Tenant?             @relation(fields: [tenantId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  creator            User?               @relation("ProductCreator", fields: [createdBy], references: [id])
  saleItems          SaleItem[]
  stockItems         StockItem[]
  stockAdjustments   StockAdjustment[]
  inventoryAuditLogs InventoryAuditLog[] @relation("AuditProduct")
  prescriptionItems  PrescriptionItem[]
  refillReminders    RefillReminder[]

  @@unique([tenantId, sku])
  @@index([name])
  @@index([isActive])
  @@index([supplierId])
  // Hot path: inventory list query filters by tenantId + isActive
  @@index([tenantId, isActive])
}

model Supplier {
  id          Int      @id @default(autoincrement())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  isActive    Boolean  @default(true)
  tenantId    String?
  createdAt   DateTime @default(now())

  tenant             Tenant?             @relation(fields: [tenantId], references: [id])
  products           Product[]
  inventoryAuditLogs InventoryAuditLog[] @relation("AuditSupplier")
  goodsReceivedNotes GoodsReceivedNote[]

  @@index([name])
  @@index([tenantId, isActive])
}

model StockAdjustment {
  id          Int      @id @default(autoincrement())
  productId   Int
  adjustedBy  Int
  oldQuantity Int
  newQuantity Int
  delta       Int // new - old
  reason      String // enum value
  notes       String?
  tenantId    String?
  branchId    String?  // branch where the adjustment was made
  adjustedAt  DateTime @default(now())

  product  Product @relation(fields: [productId], references: [id])
  adjuster User    @relation("StockAdjuster", fields: [adjustedBy], references: [id])
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  branch   Branch? @relation(fields: [branchId], references: [id])

  @@index([productId])
  @@index([tenantId, adjustedAt(sort: Desc)])
  @@index([branchId, adjustedAt(sort: Desc)])
}

model InventoryAuditLog {
  id          Int       @id @default(autoincrement())
  actionType  String // e.g. PRODUCT_CREATED, PRICE_UPDATED, etc.
  productId   Int?
  supplierId  Int?
  performedBy Int
  oldValue    Json? // snapshot before change
  newValue    Json? // snapshot after change
  notes       String?
  tenantId    String?
  performedAt DateTime  @default(now())
  revertedAt  DateTime? // null = not reverted
  revertedBy  Int? // userId who reverted
  revertNote  String? // optional reason for revert

  product   Product?  @relation("AuditProduct", fields: [productId], references: [id])
  supplier  Supplier? @relation("AuditSupplier", fields: [supplierId], references: [id])
  performer User      @relation("AuditPerformer", fields: [performedBy], references: [id])
  reverter  User?     @relation("AuditReverter", fields: [revertedBy], references: [id])
  tenant    Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([productId])
  @@index([performedAt(sort: Desc)])
  @@index([tenantId, performedAt(sort: Desc)])
  @@index([actionType])
}

model Category {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  markupPercent Float   @default(30) // default markup % for this category
  tenantId      String?

  @@index([tenantId])
}

// Customer doubles as the Patient record (blueprint §6.4, §7.5).
model Customer {
  id                Int       @id @default(autoincrement())
  name              String
  phone             String?
  loyaltyPoints     Int       @default(0)
  createdAt         DateTime  @default(now())
  tenantId          String?
  // Patient/clinical fields
  dateOfBirth       DateTime?
  gender            String? // male | female | other
  address           String?
  knownAllergies    String?
  chronicConditions String?
  tenant            Tenant?         @relation(fields: [tenantId], references: [id])
  sales             Sale[]
  prescriptions     Prescription[]
  refillReminders   RefillReminder[]

  @@unique([tenantId, phone])
}

model Sale {
  id          Int        @id @default(autoincrement())
  totalAmount Float
  discount    Float      @default(0)
  paymentType String
  status      String
  customerId  Int?
  sellerId    Int
  createdAt   DateTime   @default(now())
  tenantId    String?
  branchId    String?    // branch where the sale occurred
  clientToken String?    @unique
  miscItems   String?
  voidReason  String? // mandatory when status = voided
  voidedBy    Int? // manager (branch_manager+) who voided
  voidedAt    DateTime?
  prescriptionId Int? // linked prescription, if dispensed against one
  customer    Customer?     @relation(fields: [customerId], references: [id])
  prescription Prescription? @relation(fields: [prescriptionId], references: [id])
  tenant      Tenant?       @relation(fields: [tenantId], references: [id])
  branch      Branch?       @relation(fields: [branchId], references: [id])
  items       SaleItem[]
  payments    SalePayment[]

  // Dashboards & reports query sales by tenant within a date range
  @@index([tenantId, createdAt(sort: Desc)])
  // Branch-scoped sales lists and EOD reconciliation
  @@index([branchId, createdAt(sort: Desc)])
  @@index([customerId])
}

model SaleItem {
  id          Int        @id @default(autoincrement())
  saleId      Int
  productId   Int
  stockItemId Int? // specific batch sold (FIFO) — nullable for pre-Phase-2 sales
  quantity    Int
  price       Float
  product     Product    @relation(fields: [productId], references: [id])
  sale        Sale       @relation(fields: [saleId], references: [id])
  stockItem   StockItem? @relation(fields: [stockItemId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@index([stockItemId])
}

model Tenant {
  id                     String                  @id @default(cuid())
  name                   String
  subdomain              String                  @unique
  primaryColor           String                  @default("#6366f1")
  secondaryColor         String                  @default("#8b5cf6")
  logoUrl                String?
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  businessId             String?                 @unique
  legalName              String?
  address                String?
  licenceNumber          String?
  taxVatNumber           String?
  subscriptionTier       String                  @default("basic")
  primaryContact         String?
  primaryPhone           String?
  primaryEmail           String?
  baseColor              String?                 @default("#6366f1")
  contrast               Float?                  @default(0.7)
  customSidebar          Boolean                 @default(false)
  sidebarColor           String?
  auditLogs              AuditLog[]
  branches               Branch[]
  customers              Customer[]
  dynamicMenuConfigs     DynamicMenuConfig[]
  dynamicRoles           DynamicRole[]
  dynamicRolePermissions DynamicRolePermission[]
  loginAttempts          LoginAttempt[]
  menuConfigs            MenuConfig[]
  products               Product[]
  suppliers              Supplier[]
  stockAdjustments       StockAdjustment[]
  inventoryAuditLogs     InventoryAuditLog[]
  rolePermissions        RolePermission[]
  sales                  Sale[]
  featureFlags           TenantFeatureFlag[]
  users                  User[]
  stockItems             StockItem[]
  goodsReceivedNotes     GoodsReceivedNote[]
  stockMovements         StockMovement[]
  stockTakeSessions      StockTakeSession[]
  salePayments           SalePayment[]
  eodReports             EodReport[]
  prescriptions          Prescription[]
  refillReminders        RefillReminder[]
  importJobs             ImportJob[]
}

model Branch {
  id             String   @id @default(cuid())
  name           String
  tenantId       String
  address        String?
  phone          String?
  isActive       Boolean  @default(true)
  isHeadquarters Boolean  @default(false) // tenant HQ — default branch for tenant-wide actors
  createdAt      DateTime @default(now())
  tenant            Tenant              @relation(fields: [tenantId], references: [id])
  users             User[]
  sales             Sale[]
  stockAdjustments  StockAdjustment[]
  stockItems        StockItem[]
  goodsReceivedNotes GoodsReceivedNote[]
  stockMovements    StockMovement[]
  stockTakeSessions StockTakeSession[]
  salePayments      SalePayment[]
  eodReports        EodReport[]
  prescriptions     Prescription[]

  @@index([tenantId, isActive])
}

model Permission {
  id       String @id @default(cuid())
  key      String @unique
  label    String
  category String
}

model RolePermission {
  id            String @id @default(cuid())
  tenantId      String
  role          Role
  permissionKey String
  tenant        Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, role, permissionKey])
}

model MenuConfig {
  id        String @id @default(cuid())
  tenantId  String
  role      Role
  menuItems String
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, role])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String?
  action    String
  metadata  String?
  createdAt DateTime @default(now())
  ipAddress String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
}

model DynamicRole {
  id          String                  @id @default(cuid())
  tenantId    String?
  name        String
  slug        String
  description String?
  level       Int                     @default(3)
  isSystem    Boolean                 @default(false)
  isActive    Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  menuConfigs DynamicMenuConfig[]
  tenant      Tenant?                 @relation(fields: [tenantId], references: [id])
  permissions DynamicRolePermission[]
  users       User[]

  @@unique([tenantId, slug])
}

model DynamicRolePermission {
  id            String      @id @default(cuid())
  dynamicRoleId String
  permissionKey String
  tenantId      String
  dynamicRole   DynamicRole @relation(fields: [dynamicRoleId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([dynamicRoleId, permissionKey])
}

model DynamicMenuConfig {
  id            String      @id @default(cuid())
  dynamicRoleId String
  tenantId      String
  menuItems     String
  dynamicRole   DynamicRole @relation(fields: [dynamicRoleId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([dynamicRoleId, tenantId])
}

model FeatureFlag {
  id           String              @id @default(cuid())
  key          String              @unique
  label        String
  description  String?
  category     String
  isGloballyOn Boolean             @default(false)
  createdAt    DateTime            @default(now())
  tenantFlags  TenantFeatureFlag[]
}

model TenantFeatureFlag {
  id            String      @id @default(cuid())
  tenantId      String
  featureFlagId String
  isEnabled     Boolean     @default(false)
  featureFlag   FeatureFlag @relation(fields: [featureFlagId], references: [id])
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, featureFlagId])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String?
  username  String?
  tenantId  String?
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  // Hot path: IP rate-limit counts failures by ipAddress within a time window
  @@index([ipAddress, createdAt])
}

// ─── Phase 7: Import / migration tracking (blueprint §13.5) ──────────────────

model ImportJob {
  id            Int       @id @default(autoincrement())
  tenantId      String
  entityType    String // product | stock | supplier | patient | user | sale
  fileName      String?
  status        String    @default("pending") // pending | validating | awaiting_confirmation | processing | completed | failed
  totalRows     Int       @default(0)
  successCount  Int       @default(0)
  failureCount  Int       @default(0)
  failureReport String? // serialized failure rows/reasons (no object storage here)
  performedBy   Int
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
}

// ─── Phase 4: Clinical — prescriptions + refills (blueprint §6.4, §7.5) ──────

model Prescription {
  id            Int       @id @default(autoincrement())
  tenantId      String
  branchId      String?
  patientId     Int // → Customer (patient record)
  prescriberName String?
  status        String    @default("issued") // issued | verified | dispensed | voided
  notes         String?
  issuedBy      Int
  verifiedBy    Int?
  dispensedBy   Int?
  voidReason    String?
  createdAt     DateTime  @default(now())
  verifiedAt    DateTime?
  dispensedAt   DateTime?

  tenant  Tenant             @relation(fields: [tenantId], references: [id])
  branch  Branch?            @relation(fields: [branchId], references: [id])
  patient Customer           @relation(fields: [patientId], references: [id])
  items   PrescriptionItem[]
  sales   Sale[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([patientId])
  @@index([status])
}

model PrescriptionItem {
  id             Int     @id @default(autoincrement())
  prescriptionId Int
  productId      Int?
  drugName       String
  dosage         String?
  quantity       Int     @default(1)
  instructions   String?

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id])

  @@index([prescriptionId])
}

model RefillReminder {
  id                Int      @id @default(autoincrement())
  tenantId          String
  patientId         Int
  productId         Int
  lastDispensedAt   DateTime
  refillIntervalDays Int
  nextRefillDate    DateTime
  reminderDaysBefore Int     @default(3)
  status            String   @default("active") // active | dismissed | fulfilled | snoozed
  createdBy         Int
  createdAt         DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  patient Customer @relation(fields: [patientId], references: [id])
  product Product  @relation(fields: [productId], references: [id])

  @@index([tenantId, nextRefillDate])
  @@index([patientId])
  @@index([status])
}

// ─── Phase 3: POS — split payments + EOD (blueprint §6.3, §7.4) ──────────────

// Immutable, append-only — one row per tender on a sale (supports split payment).
model SalePayment {
  id            Int      @id @default(autoincrement())
  saleId        Int
  tenantId      String
  branchId      String?
  paymentMethod String // cash | mobile_money | card | credit
  amount        Float
  reference     String? // MoMo txn id, card auth code, etc.
  createdAt     DateTime @default(now())

  sale   Sale    @relation(fields: [saleId], references: [id])
  tenant Tenant  @relation(fields: [tenantId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([saleId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([branchId, createdAt(sort: Desc)])
}

// End-of-day reconciliation — one per branch per trading day; immutable once written.
model EodReport {
  id           Int      @id @default(autoincrement())
  tenantId     String
  branchId     String
  businessDate DateTime // trading day (date component)
  totalSales   Float
  totalReturns Float    @default(0)
  netRevenue   Float
  byMethod     Json // { cash, mobile_money, card, credit }
  expectedCash Float
  countedCash  Float
  cashVariance Float
  notes        String?
  submittedBy  Int
  submittedAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, businessDate])
  @@index([tenantId, businessDate(sort: Desc)])
}

// ─── Phase 2: Batch-level inventory (blueprint §6.2, §7.3) ───────────────────
// stock lives per batch, per branch. Product remains the tenant-wide catalog.

model StockItem {
  id              Int       @id @default(autoincrement())
  tenantId        String
  branchId        String
  productId       Int
  batchNumber     String?
  expiryDate      DateTime?
  quantity        Int       @default(0)
  costPrice       Float // unit cost at receiving (wholesale)
  markupPercent   Float     @default(0)
  sellingPrice    Float // auto-calculated: cost × (1 + markup/100)
  priceOverridden Boolean   @default(false)
  grnId           Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant    Tenant             @relation(fields: [tenantId], references: [id])
  branch    Branch             @relation(fields: [branchId], references: [id])
  product   Product            @relation(fields: [productId], references: [id])
  grn       GoodsReceivedNote? @relation(fields: [grnId], references: [id])
  movements StockMovement[]
  saleItems SaleItem[]

  // FIFO selection: oldest received batch with stock, per product+branch
  @@index([tenantId, branchId, productId])
  @@index([productId])
  @@index([branchId, quantity])
  @@index([expiryDate])
}

model GoodsReceivedNote {
  id            Int      @id @default(autoincrement())
  tenantId      String
  branchId      String
  supplierId    Int?
  grnNumber     String?
  invoiceNumber String?
  notes         String?
  receivedBy    Int
  createdAt     DateTime @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  branch     Branch      @relation(fields: [branchId], references: [id])
  supplier   Supplier?   @relation(fields: [supplierId], references: [id])
  receiver   User        @relation("GrnReceiver", fields: [receivedBy], references: [id])
  stockItems StockItem[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([branchId, createdAt(sort: Desc)])
}

// Immutable, append-only ledger — no updatedAt, no soft delete.
model StockMovement {
  id             Int      @id @default(autoincrement())
  tenantId       String
  branchId       String
  stockItemId    Int
  movementType   String // grn | adjustment | sale | return | transfer_in | transfer_out | write_off | stock_take | import
  quantityChange Int // positive = in, negative = out
  quantityBefore Int
  quantityAfter  Int
  referenceId    Int? // loose ref to GRN, sale, adjustment, or stock_take_session
  reason         String?
  performedBy    Int
  createdAt      DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  branch    Branch    @relation(fields: [branchId], references: [id])
  stockItem StockItem @relation(fields: [stockItemId], references: [id])
  performer User      @relation("MovementPerformer", fields: [performedBy], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([stockItemId])
  @@index([branchId, createdAt(sort: Desc)])
  @@index([movementType])
}

model StockTakeSession {
  id                 Int       @id @default(autoincrement())
  tenantId           String
  branchId           String
  status             String // in_progress | completed | cancelled
  itemsChecked       Int       @default(0)
  discrepanciesFound Int       @default(0)
  initiatedBy        Int
  completedBy        Int?
  startedAt          DateTime  @default(now())
  completedAt        DateTime?

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  branch    Branch @relation(fields: [branchId], references: [id])
  initiator User   @relation("StockTakeInitiator", fields: [initiatedBy], references: [id])
  completer User?  @relation("StockTakeCompleter", fields: [completedBy], references: [id])

  @@index([tenantId, startedAt(sort: Desc)])
  @@index([branchId, status])
}

enum Role {
  SUPER_ADMIN
  MANAGER
  MCA
  NES
}
