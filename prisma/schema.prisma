generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int          @id @default(autoincrement())
  username           String       @unique
  password           String
  role               String
  contact            String?
  createdAt          DateTime     @default(now())
  email              String?      @unique
  passwordHash       String?
  saasRole           Role?
  tenantId           String?
  branchId           String?
  isActive           Boolean      @default(true)
  lastActiveAt       DateTime?
  dynamicRoleId      String?
  businessUsername   String?
  mustChangePassword Boolean      @default(false)
  failedLoginCount   Int          @default(0)
  lockedUntil        DateTime?
  lastPasswordChange DateTime?
  branch             Branch?      @relation(fields: [branchId], references: [id])
  dynamicRole        DynamicRole? @relation(fields: [dynamicRoleId], references: [id])
  tenant             Tenant?      @relation(fields: [tenantId], references: [id])
}

model Product {
  id          Int        @id @default(autoincrement())
  name        String
  category    String
  price       Float
  costPrice   Float?
  stockQty    Int        @default(0)
  expiryDate  DateTime?
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenantId    String?
  tenant      Tenant?    @relation(fields: [tenantId], references: [id])
  saleItems   SaleItem[]
}

model Category {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  tenantId String?
}

model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String?
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())
  tenantId      String?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])
  sales         Sale[]

  @@unique([tenantId, phone])
}

model Sale {
  id          Int        @id @default(autoincrement())
  totalAmount Float
  discount    Float      @default(0)
  paymentType String
  status      String
  customerId  Int?
  sellerId    Int
  createdAt   DateTime   @default(now())
  tenantId    String?
  clientToken String?    @unique
  customer    Customer?  @relation(fields: [customerId], references: [id])
  tenant      Tenant?    @relation(fields: [tenantId], references: [id])
  items       SaleItem[]
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  productId Int
  quantity  Int
  price     Float
  product   Product @relation(fields: [productId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id])
}

model Tenant {
  id                     String                  @id @default(cuid())
  name                   String
  subdomain              String                  @unique
  primaryColor           String                  @default("#6366f1")
  secondaryColor         String                  @default("#8b5cf6")
  logoUrl                String?
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  businessId             String?                 @unique
  legalName              String?
  address                String?
  licenceNumber          String?
  taxVatNumber           String?
  subscriptionTier       String                  @default("basic")
  primaryContact         String?
  primaryPhone           String?
  primaryEmail           String?
  baseColor              String?                 @default("#6366f1")
  contrast               Float?                  @default(0.7)
  customSidebar          Boolean                 @default(false)
  sidebarColor           String?
  auditLogs              AuditLog[]
  branches               Branch[]
  customers              Customer[]
  dynamicMenuConfigs     DynamicMenuConfig[]
  dynamicRoles           DynamicRole[]
  dynamicRolePermissions DynamicRolePermission[]
  loginAttempts          LoginAttempt[]
  menuConfigs            MenuConfig[]
  products               Product[]
  rolePermissions        RolePermission[]
  sales                  Sale[]
  featureFlags           TenantFeatureFlag[]
  users                  User[]
}

model Branch {
  id       String  @id @default(cuid())
  name     String
  tenantId String
  address  String?
  phone    String?
  isActive Boolean @default(true)
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  users    User[]
}

model Permission {
  id       String @id @default(cuid())
  key      String @unique
  label    String
  category String
}

model RolePermission {
  id            String @id @default(cuid())
  tenantId      String
  role          Role
  permissionKey String
  tenant        Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, role, permissionKey])
}

model MenuConfig {
  id        String @id @default(cuid())
  tenantId  String
  role      Role
  menuItems String
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, role])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String?
  action    String
  metadata  String?
  createdAt DateTime @default(now())
  ipAddress String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
}

model DynamicRole {
  id          String                  @id @default(cuid())
  tenantId    String?
  name        String
  slug        String
  description String?
  level       Int                     @default(3)
  isSystem    Boolean                 @default(false)
  isActive    Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  menuConfigs DynamicMenuConfig[]
  tenant      Tenant?                 @relation(fields: [tenantId], references: [id])
  permissions DynamicRolePermission[]
  users       User[]

  @@unique([tenantId, slug])
}

model DynamicRolePermission {
  id            String      @id @default(cuid())
  dynamicRoleId String
  permissionKey String
  tenantId      String
  dynamicRole   DynamicRole @relation(fields: [dynamicRoleId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([dynamicRoleId, permissionKey])
}

model DynamicMenuConfig {
  id            String      @id @default(cuid())
  dynamicRoleId String
  tenantId      String
  menuItems     String
  dynamicRole   DynamicRole @relation(fields: [dynamicRoleId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([dynamicRoleId, tenantId])
}

model FeatureFlag {
  id           String              @id @default(cuid())
  key          String              @unique
  label        String
  description  String?
  category     String
  isGloballyOn Boolean             @default(false)
  createdAt    DateTime            @default(now())
  tenantFlags  TenantFeatureFlag[]
}

model TenantFeatureFlag {
  id            String      @id @default(cuid())
  tenantId      String
  featureFlagId String
  isEnabled     Boolean     @default(false)
  featureFlag   FeatureFlag @relation(fields: [featureFlagId], references: [id])
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, featureFlagId])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String?
  username  String?
  tenantId  String?
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
}

enum Role {
  SUPER_ADMIN
  MANAGER
  MCA
  NES
}
