# ── Database ──────────────────────────────────────────────────────────────────
# For production, use PostgreSQL:
DATABASE_URL="postgresql://pharmnext:CHANGE_ME@localhost:5432/pharmnext?schema=public"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# IMPORTANT: Generate a unique secret:  openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_A_REAL_SECRET"
NEXTAUTH_URL="https://your-domain.com"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="production"
