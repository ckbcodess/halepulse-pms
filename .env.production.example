# ── Database ──────────────────────────────────────────────────────────────────
# For production, use PostgreSQL:
DATABASE_URL="postgresql://pharmnext:CHANGE_ME@localhost:5432/pharmnext?schema=public"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# IMPORTANT: Generate a unique secret:  openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_A_REAL_SECRET"
NEXTAUTH_URL="https://your-domain.com"

# ── Google OAuth (optional) ────────────────────────────────────────────────────
# Enables "Sign in with Google" on the login page.
# Enterprise pattern: only pre-provisioned users may sign in — no self-registration.
#
# Setup steps:
#   1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID (Web application)
#   3. Add Authorized redirect URI:
#        https://your-domain.com/api/auth/callback/google
#        (for local dev: http://localhost:3000/api/auth/callback/google)
#   4. Copy the Client ID and Secret below
#
# Leave blank to disable Google sign-in (credentials login still works).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Seeding ────────────────────────────────────────────────────────────────────
# Set to 'false' to skip demo tenant/user seeding in production
SEED_DEMO_DATA="false"
# Override the super admin password (must be set in production)
SUPER_ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# ── AI (provider-agnostic) ──────────────────────────────────────────────────────
# Server-side only — powers AI features (monthly report narrative, drug
# interaction checks). Leave everything blank to disable AI (endpoints return 503).
# Works with ANY OpenAI-compatible provider — see docs/AI_SETUP.md for copy-paste
# settings (Gemini free tier, OpenRouter free models, Groq, local Ollama).
#
# Option A — OpenAI-compatible (recommended; covers Gemini/OpenRouter/Groq/Ollama):
AI_BASE_URL=""   # e.g. https://generativelanguage.googleapis.com/v1beta/openai
AI_API_KEY=""    # your provider key
AI_MODEL=""      # e.g. gemini-2.0-flash  |  deepseek/deepseek-chat:free  |  llama-3.3-70b
#
# Option B — Anthropic Claude (used automatically if only this is set):
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=""   # optional, default: claude-sonnet-4-6
#
# Force a transport explicitly (optional): AI_PROVIDER="openai" or "anthropic"
AI_PROVIDER=""

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="production"
