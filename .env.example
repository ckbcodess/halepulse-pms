# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored — it stays on your machine and is NEVER committed.
# Each developer points at their OWN local database.

# --- Database ---------------------------------------------------------------
# Local Postgres via Docker (recommended for dev). Start the DB with:
#   docker run --name halepulse-db -e POSTGRES_PASSWORD=devpass -e POSTGRES_DB=halepulse -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:devpass@localhost:5432/halepulse?sslmode=disable"

# --- Auth (NextAuth) --------------------------------------------------------
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
